# Build outputs
bin/
obj/
staged/
*.pdb

# Visual Studio
.vs/
*.user
*.suo
*.csproj.user

# NuGet
packages/
.nuget/

# Node.js
node_modules/

# Sensitive files
.mcp.json
.env
.env.local
.env.*.local
.claude/settings.local.json
# MultiRemote gateway credential override (task ca6c5344). appsettings.json ships
# changeme defaults; the real Auth:Username/Password live here, dropped next to the
# exe per install and never committed.
appsettings.Local.json
# MT-managed project definition: changeLog is appended on every task-done,
# so it's perpetually dirty. Untracked here (repo has no remote; MT regenerates
# it via the add-project flow). History up to 3e9711e remains in past commits.
.claude/project.json

# Databases & sessions
*.db
*.sqlite
*.sqlite3
.claude/sessions.db
.claude/sync-debug.log

# Session history (large, regeneratable)
mcp-session-history/

# Logs & temp
*.log
debug-log-*.txt
*.tmp
*.temp

# Daily-intel CLI changelog scratch (transient; kept changelogs are cc-changelog-*/changelog-*).
# Without this these tmp-* files surface as unattributed working changes ("Needs a quick task").
CLI Research/tmp-*.md

# OS files
.DS_Store
Thumbs.db

# Git-stint worktrees
.stint/

# Per-task worktrees (materialized by WorktreeManager on set_task_active)
# Relocated under .claude/worktrees/ for Claude Code EnterWorktree(path=...) support
# (task 0134ec2f). Legacy /worktrees/ kept for transition / pre-existing trees.
.claude/worktrees/
/worktrees/

# Transient agent/runtime state (regeneratable, not team-wide)
.claude/scheduled_tasks.lock
.claude/tmp/
memory/
.codesight/

# Misc artifacts
nul
cq-windows-amd64.exe

# Forensic captures from agent sessions (ephemeral debug data)
.forensic/

# Pipeline focus artifacts (per-run, regenerated by /pipeline)
.pipeline-tmp/
.pipeline-focus-*.txt

# Codex cross-model gate focus artifacts (per-run, regenerated by the codex pipeline agents)
.codex-focus-*.txt

# Scratch HTML mockups (underscore prefix convention)
scripts/_*.html
