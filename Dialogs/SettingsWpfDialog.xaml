<Window x:Class="MultiTerminal.Dialogs.SettingsWpfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="880" Height="740"
        MinWidth="880" MaxWidth="880"
        MinHeight="740" MaxHeight="740"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Flat dark TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat dark PasswordBox style (masked secrets — mirrors DarkTextBox) -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton style used inside ComboBox template (invisible, covers entire area) -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat dark ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,4,28,4"
                                                      VerticalAlignment="Center"
                                                      TextBlock.FontSize="{TemplateBinding FontSize}"
                                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                                      TextBlock.FontFamily="{TemplateBinding FontFamily}"/>
                                    <TextBlock x:Name="Arrow"
                                               Text="&#x25BC;"
                                               FontSize="9"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <!-- ToggleButton covers entire area to open/close dropdown -->
                            <ToggleButton Style="{StaticResource ComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="200">
                                    <Border Background="#2D2D30"
                                            BorderBrush="#3E3E42"
                                            BorderThickness="1">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E3E42"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Accent (OK) button style -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#008CE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="12,6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cancel button style -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="12,6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505054"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5A5A5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small action button style (Add/Edit/Delete/Set Default) -->
        <Style x:Key="SmallActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505054"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5A5A5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark GroupBox style -->
        <Style x:Key="DarkGroupBox" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="0"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="SemiBold"
                                       Background="#1E1E1E"
                                       Padding="4,0"
                                       Margin="10,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark RadioButton style -->
        <Style x:Key="DarkRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Dark DataGrid style -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3E3E42"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3E3E42"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#A0A0A0"/>
                        <Setter Property="BorderBrush" Value="#3E3E42"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#252526"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A3A5C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark TabControl style -->
        <Style x:Key="DarkTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Dark TabItem style -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3,3,0,0"
                                Margin="0,0,2,-1">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="16,16,16,8" Style="{StaticResource DarkTabControl}">
            <TabItem Header="General" Style="{StaticResource DarkTabItem}">

        <!-- Two-column form content (ScrollViewer guards against clipping at the fixed window height) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0">

                <!-- SECTION 0: General -->
                <GroupBox Header="General"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Text="Default Working Directory (Just Claude)"
                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DefaultWorkingDirText"
                                     Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     Foreground="#FFFFFF"
                                     Height="32"
                                     FontSize="12"
                                     VerticalAlignment="Center"
                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <Button x:Name="BrowseDefaultDirButton"
                                    Grid.Column="1"
                                    Content="Browse..."
                                    Style="{StaticResource SmallActionButton}"
                                    Width="80" Height="32"
                                    VerticalAlignment="Center"
                                    Margin="6,0,0,0"
                                    Click="BrowseDefaultDirButton_Click"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- SECTION 1: Font Sizes -->
                <GroupBox Header="Font Sizes"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <Grid Margin="4,8,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Toolbar"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ToolbarFontCombo" Grid.Row="0" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Terminal"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="TerminalFontCombo" Grid.Row="1" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Project Panel"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ProjectPanelFontCombo" Grid.Row="2" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Chat Panel"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ChatPanelFontCombo" Grid.Row="3" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Tasks Panel"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="TasksPanelFontCombo" Grid.Row="4" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Activity Panel"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="ActivityPanelFontCombo" Grid.Row="5" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>
                    </Grid>
                </GroupBox>

                <!-- SECTION 2: Terminal Placement -->
                <GroupBox Header="Terminal Placement"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <Grid Margin="4,8,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Grids"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MaxGridsCombo" Grid.Row="0" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Tabs per Grid"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MaxTabsCombo" Grid.Row="1" Grid.Column="1"
                                  Style="{StaticResource DarkComboBox}" Height="26"/>
                    </Grid>
                </GroupBox>

                <!-- SECTION 2b: Git -->
                <GroupBox Header="Git"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <StackPanel Margin="4,8,4,4">
                        <CheckBox x:Name="WorktreeModeCheck"
                                  Content="Per-task worktree isolation"
                                  Foreground="#E0E0E0"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  VerticalContentAlignment="Center"/>
                        <TextBlock Text="Each active task runs in its own git worktree on its own branch. Auto-commits at task done and merges into trunk. Requires app restart to take effect. The MULTITERMINAL_WORKTREE_MODE environment variable, if set, overrides this."
                                   Foreground="#808080"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="22,4,0,0"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">

                <!-- SECTION 3: Agent Panel -->
                <GroupBox Header="Agent Panel"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <StackPanel Margin="4,8,4,4">

                        <TextBlock Text="Layout"
                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <RadioButton x:Name="SplitRightRadio"
                                         Grid.Row="0" Grid.Column="0"
                                         Content="Split Right"
                                         GroupName="AgentLayout"
                                         Style="{StaticResource DarkRadioButton}"/>
                            <RadioButton x:Name="SplitBelowRadio"
                                         Grid.Row="0" Grid.Column="1"
                                         Content="Split Below"
                                         GroupName="AgentLayout"
                                         Style="{StaticResource DarkRadioButton}"/>
                            <RadioButton x:Name="TabbedRightRadio"
                                         Grid.Row="1" Grid.Column="0"
                                         Content="Tabbed Right"
                                         GroupName="AgentLayout"
                                         Style="{StaticResource DarkRadioButton}"/>
                            <RadioButton x:Name="DoNotShowRadio"
                                         Grid.Row="1" Grid.Column="1"
                                         Content="Do Not Show"
                                         GroupName="AgentLayout"
                                         Style="{StaticResource DarkRadioButton}"/>
                        </Grid>

                        <TextBlock Text="On Complete"
                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <RadioButton x:Name="AutoCloseRadio"
                                         Content="Auto-close"
                                         GroupName="AgentCloseMode"
                                         Style="{StaticResource DarkRadioButton}"
                                         Margin="0,0,24,0"/>
                            <RadioButton x:Name="KeepOpenRadio"
                                         Content="Keep open"
                                         GroupName="AgentCloseMode"
                                         Style="{StaticResource DarkRadioButton}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- SECTION 4: Claude Commands -->
                <GroupBox Header="Claude Commands"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <StackPanel Margin="4,8,4,4">

                        <DataGrid x:Name="CommandsGrid"
                                  Style="{StaticResource DarkDataGrid}"
                                  Height="150"
                                  Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Command"
                                                    Binding="{Binding Command}"
                                                    Width="*"
                                                    IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="Default"
                                                        Binding="{Binding IsDefault}"
                                                        Width="70"
                                                        IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AddCommandButton"
                                    Content="Add"
                                    Style="{StaticResource SmallActionButton}"
                                    Width="60" Height="26"
                                    Margin="0,0,6,0"
                                    Click="AddCommandButton_Click"/>
                            <Button x:Name="EditCommandButton"
                                    Content="Edit"
                                    Style="{StaticResource SmallActionButton}"
                                    Width="60" Height="26"
                                    Margin="0,0,6,0"
                                    Click="EditCommandButton_Click"/>
                            <Button x:Name="DeleteCommandButton"
                                    Content="Delete"
                                    Style="{StaticResource SmallActionButton}"
                                    Width="60" Height="26"
                                    Margin="0,0,6,0"
                                    Click="DeleteCommandButton_Click"/>
                            <Button x:Name="SetDefaultCommandButton"
                                    Content="Set Default"
                                    Style="{StaticResource SmallActionButton}"
                                    Width="90" Height="26"
                                    Click="SetDefaultCommandButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- SECTION 5: User Profile -->
                <GroupBox Header="User Profile"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <Grid Margin="4,8,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ProfileSummaryText"
                                   Grid.Column="0"
                                   Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Not configured"/>
                        <Button x:Name="EditProfileButton"
                                Grid.Column="1"
                                Content="Edit Profile"
                                Style="{StaticResource SmallActionButton}"
                                Width="90" Height="26"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Click="EditProfileButton_Click"/>
                    </Grid>
                </GroupBox>

                <!-- SECTION 6: Source Control Accounts -->
                <GroupBox Header="Source Control Accounts"
                          Style="{StaticResource DarkGroupBox}"
                          Margin="0,0,0,10">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Text="Manage GitHub and Bitbucket accounts for repo operations and commit attribution."
                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="ManageSourceControlAccountsButton"
                                Content="Manage Source Control Accounts"
                                Style="{StaticResource SmallActionButton}"
                                Height="28"
                                HorizontalAlignment="Left"
                                Padding="16,0,16,0"
                                Click="ManageSourceControlAccountsButton_Click"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </Grid>
        </ScrollViewer>
            </TabItem>

            <TabItem Header="Pipeline" Style="{StaticResource DarkTabItem}">
                <StackPanel Margin="16,16,16,16">
                    <TextBlock Text="Assign each /pipeline role to a provider, or turn it off entirely. Changes take effect on the next /pipeline run."
                               Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="12"
                               Margin="4,4,4,16"
                               TextWrapping="Wrap"/>

                    <GroupBox Header="Gate Providers"
                              Style="{StaticResource DarkGroupBox}"
                              Margin="0,0,0,10">
                        <Grid Margin="8,12,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Verifier"
                                       Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="VerifierProviderCombo" Grid.Row="0" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" Height="28"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Code Reviewer"
                                       Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="CodeReviewerProviderCombo" Grid.Row="1" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" Height="28"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Security Auditor"
                                       Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="SecurityAuditorProviderCombo" Grid.Row="2" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" Height="28"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Debugger"
                                       Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="DebuggerProviderCombo" Grid.Row="3" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" Height="28"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Cross-Model Adversary"
                                       Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="CrossModelAdversaryProviderCombo" Grid.Row="4" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}" Height="28"/>
                        </Grid>
                    </GroupBox>

                    <TextBlock Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                               Margin="4,0,4,0"
                               TextWrapping="Wrap"
                               Text="Defaults: Verifier / Code Reviewer / Security Auditor / Debugger run on Claude. Cross-Model Adversary is off. Selecting Codex requires the Codex plugin to be installed and authenticated."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Codex" Style="{StaticResource DarkTabItem}">
                <StackPanel Margin="16,16,16,16">
                    <TextBlock Text="Configure the Codex CLI used for Codex terminal launches. These values are picked up on the next Codex terminal start."
                               Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="12"
                               Margin="4,4,4,16"
                               TextWrapping="Wrap"/>

                    <GroupBox Header="Codex CLI"
                              Style="{StaticResource DarkGroupBox}"
                              Margin="0,0,0,10">
                        <StackPanel Margin="8,12,8,8">

                            <TextBlock Text="Binary path (optional — blank resolves via PATH)"
                                       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="CodexBinaryPathText"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="28"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Model (e.g. gpt-5, gpt-5-turbo) — blank uses Codex default"
                                       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="CodexModelText"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="28"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Reasoning effort"
                                       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="CodexEffortCombo"
                                      Style="{StaticResource DarkComboBox}"
                                      Height="28"
                                      Margin="0,0,0,12"/>

                            <TextBlock Text="Default agent name (used when a Codex terminal launches without a team-lead identity)"
                                       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="CodexDefaultAgentNameText"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="28"/>

                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Broker Health"
                              Style="{StaticResource DarkGroupBox}"
                              Margin="0,0,0,10">
                        <StackPanel Margin="8,12,8,8">

                            <TextBlock Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"
                                       Text="If Codex reports 'not authenticated' even after running 'codex login', the companion's cached broker.json may be pointing at a dead pipe (this happens after MT host restarts and machine reboots). Click below to reset the broker state for ALL workspaces."/>

                            <Button x:Name="ResetCodexBrokerButton"
                                    Content="Reset Codex broker"
                                    Style="{StaticResource SmallActionButton}"
                                    Height="28"
                                    HorizontalAlignment="Left"
                                    Padding="16,0,16,0"
                                    Click="ResetCodexBrokerButton_Click"/>

                        </StackPanel>
                    </GroupBox>

                    <TextBlock Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                               Margin="4,0,4,0"
                               TextWrapping="Wrap"
                               Text="Phase 1: the binary path and default agent name are applied on launch. Model / effort are persisted here and can be wired into ~/.codex/config.toml in a follow-up."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Multi-Connect" Style="{StaticResource DarkTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,16,16,16">
                        <TextBlock Text="Self-service phone connectivity. Each field shows its effective value and where it resolves from (settings / appsettings / default) so you never edit into a shadow. Clearing a field falls back to the appsettings default. Restart-required fields re-apply the gateway when you click OK."
                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="12"
                                   Margin="4,4,4,16"
                                   TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT COLUMN: Network + Tailscale -->
                            <StackPanel Grid.Column="0">

                                <GroupBox Header="Network"
                                          Style="{StaticResource DarkGroupBox}"
                                          Margin="0,0,0,10">
                                    <StackPanel Margin="8,12,8,8">
                                        <TextBlock Text="Gateway port  —  restart required"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="MC_GatewayPortText"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Height="28"/>
                                        <TextBlock x:Name="MC_GatewayPortSource"
                                                   Text="(source: default)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Tailscale"
                                          Style="{StaticResource DarkGroupBox}"
                                          Margin="0,0,0,10">
                                    <StackPanel Margin="8,12,8,8">
                                        <CheckBox x:Name="MC_TailscaleEnabledCheck"
                                                  Content="Enable Tailscale integration"
                                                  Foreground="#E0E0E0" FontFamily="Segoe UI" FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  Margin="0,0,0,10"/>

                                        <TextBlock Text="Hostname (.ts.net)"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="MC_TailscaleHostnameText"
                                                     Grid.Column="0"
                                                     Style="{StaticResource DarkTextBox}"
                                                     Height="28"
                                                     TextChanged="MC_RecomputeUrl_TextChanged"/>
                                            <Button x:Name="MC_DetectButton"
                                                    Grid.Column="1"
                                                    Content="Detect"
                                                    Style="{StaticResource SmallActionButton}"
                                                    Width="72" Height="28"
                                                    Margin="6,0,0,0"
                                                    Click="MC_DetectButton_Click"/>
                                        </Grid>
                                        <TextBlock x:Name="MC_TailscaleHostnameSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="Tailscale serve HTTPS port"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="MC_ServePortText"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Height="28"
                                                 TextChanged="MC_RecomputeUrl_TextChanged"/>
                                        <TextBlock x:Name="MC_ServePortSource"
                                                   Text="(source: default)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="Phone URL"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="MC_PhoneUrlText"
                                                     Grid.Column="0"
                                                     Style="{StaticResource DarkTextBox}"
                                                     Height="28"
                                                     IsReadOnly="True"
                                                     Foreground="#C0C0C0"/>
                                            <Button x:Name="MC_CopyUrlButton"
                                                    Grid.Column="1"
                                                    Content="Copy"
                                                    Style="{StaticResource SmallActionButton}"
                                                    Width="72" Height="28"
                                                    Margin="6,0,0,0"
                                                    Click="MC_CopyUrlButton_Click"/>
                                        </Grid>

                                        <Button x:Name="MC_TestButton"
                                                Content="Test connection"
                                                Style="{StaticResource SmallActionButton}"
                                                Height="28"
                                                HorizontalAlignment="Left"
                                                Padding="16,0,16,0"
                                                Margin="0,10,0,10"
                                                Click="MC_TestButton_Click"/>

                                        <Border Background="#252526"
                                                BorderBrush="#3E3E42"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                MinHeight="48">
                                            <TextBlock x:Name="MC_TailscaleStatusText"
                                                       Text="Status: not checked. Click Detect or Test."
                                                       Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="8,6,8,6"/>
                                        </Border>
                                    </StackPanel>
                                </GroupBox>

                            </StackPanel>

                            <!-- RIGHT COLUMN: Phone Access + Relay & Push -->
                            <StackPanel Grid.Column="2">

                                <GroupBox Header="Phone Access"
                                          Style="{StaticResource DarkGroupBox}"
                                          Margin="0,0,0,10">
                                    <StackPanel Margin="8,12,8,8">
                                        <TextBlock Text="Username"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="MC_PhoneAuthUsernameText"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Height="28"/>
                                        <TextBlock x:Name="MC_PhoneAuthUsernameSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="Password"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <PasswordBox x:Name="MC_PhoneAuthPasswordBox"
                                                     Style="{StaticResource DarkPasswordBox}"
                                                     Height="28"
                                                     PasswordChanged="MC_Secret_PasswordChanged"
                                                     GotKeyboardFocus="MC_Secret_GotKeyboardFocus"
                                                     PreviewMouseLeftButtonDown="MC_Secret_PreviewMouseLeftButtonDown"/>
                                        <TextBlock x:Name="MC_PhoneAuthPasswordSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Relay &amp; Push"
                                          Style="{StaticResource DarkGroupBox}"
                                          Margin="0,0,0,10">
                                    <StackPanel Margin="8,12,8,8">
                                        <TextBlock Text="Relay BaseUrl  —  restart required"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="MC_RelayBaseUrlText"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Height="28"/>
                                        <TextBlock x:Name="MC_RelayBaseUrlSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="Relay ApiKey  —  restart required"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <PasswordBox x:Name="MC_RelayApiKeyBox"
                                                     Style="{StaticResource DarkPasswordBox}"
                                                     Height="28"
                                                     PasswordChanged="MC_Secret_PasswordChanged"
                                                     GotKeyboardFocus="MC_Secret_GotKeyboardFocus"
                                                     PreviewMouseLeftButtonDown="MC_Secret_PreviewMouseLeftButtonDown"/>
                                        <TextBlock x:Name="MC_RelayApiKeySource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="Push notification secret  —  restart required"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <PasswordBox x:Name="MC_NotificationSecretBox"
                                                     Style="{StaticResource DarkPasswordBox}"
                                                     Height="28"
                                                     PasswordChanged="MC_Secret_PasswordChanged"
                                                     GotKeyboardFocus="MC_Secret_GotKeyboardFocus"
                                                     PreviewMouseLeftButtonDown="MC_Secret_PreviewMouseLeftButtonDown"/>
                                        <TextBlock x:Name="MC_NotificationSecretSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,10"/>

                                        <TextBlock Text="VAPID subject  —  restart required"
                                                   Foreground="#A0A0A0" FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="MC_VapidSubjectText"
                                                 Style="{StaticResource DarkTextBox}"
                                                 Height="28"/>
                                        <TextBlock x:Name="MC_VapidSubjectSource"
                                                   Text="(source: not set)"
                                                   Foreground="#808080" FontFamily="Segoe UI" FontSize="11"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </GroupBox>

                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Bottom bar with OK / Cancel -->
        <Border Grid.Row="1"
                Background="#2D2D30"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="12,10">
                <Button x:Name="OkButton"
                        Style="{StaticResource AccentButton}"
                        Content="OK"
                        Height="32"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button x:Name="CancelBtn"
                        Style="{StaticResource CancelButton}"
                        Content="Cancel"
                        Height="32"
                        IsCancel="True"
                        Click="CancelBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
