<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>MultiTerminal</RootNamespace>
    <AssemblyName>MultiTerminal</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>false</Deterministic>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <!-- Specify minimum Windows version to suppress CA1416 platform warnings -->
    <SupportedOSPlatformVersion>7.0</SupportedOSPlatformVersion>
    <!-- Suppress WindowsBase version conflict from WebView2 WPF assemblies -->
    <!-- Suppress CA1416: This is a Windows-only WinForms app -->
    <!-- Suppress CS0067/CS0414: Unused events/fields (reserved for future use or designer artifacts) -->
    <NoWarn>$(NoWarn);MSB3277;CA1416;CS0067;CS0414</NoWarn>
  </PropertyGroup>

  <!-- Exclude the test project folders -->
  <ItemGroup>
    <Compile Remove="MultiTerminal.Tests\**" />
    <Content Remove="MultiTerminal.Tests\**" />
    <None Remove="MultiTerminal.Tests\**" />
    <Compile Remove="AgentProcessTest\**" />
    <Content Remove="AgentProcessTest\**" />
    <None Remove="AgentProcessTest\**" />
    <!-- Sibling git worktrees live under worktrees/ — exclude to avoid CS0111 duplicates -->
    <Compile Remove="worktrees\**" />
    <Content Remove="worktrees\**" />
    <None Remove="worktrees\**" />
    <EmbeddedResource Remove="worktrees\**" />
    <Page Remove="worktrees\**" />
    <ApplicationDefinition Remove="worktrees\**" />
    <Resource Remove="worktrees\**" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DockPanelSuite" Version="3.1.1" />
    <PackageReference Include="DockPanelSuite.ThemeVS2015" Version="3.1.1" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3800.47" />
    <PackageReference Include="SmartComponents.LocalEmbeddings" Version="0.1.0-preview10148" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="8.0.0" />
    <PackageReference Include="LibGit2Sharp" Version="0.30.0" />
    <!-- Presence-aware notification routing (task 9f9c3141): MQTT client for the MT Presence
         Adapter that ingests MSR-2 mmWave + phone BLE signals and drives MessageBroker.SetRemoteMode.
         Pinned to the 4.3.x line (MqttFactory API; v5 renamed it to MqttClientFactory). -->
    <PackageReference Include="MQTTnet" Version="4.3.7.1207" />
    <!-- MultiRemote phone-gateway Web Push (Phase 2, task ca6c5344, item [7]).
         VAPID key gen + RFC8291 payload encryption for Apple/Web Push. Same version
         the standalone MultiRemote shipped, so existing push-config.json keys load as-is. -->
    <PackageReference Include="WebPush" Version="1.0.12" />
    <!-- DPAPI (ProtectedData, CurrentUser scope) for at-rest encryption of the three
         Multi-Connect secrets in settings.txt (phone password, relay ApiKey, push
         NotificationSecret). Not in the shared framework even on net8.0-windows. Task 642c14e3. -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

  <!-- Analyzers: build-time only, not a runtime dependency. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="9.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
