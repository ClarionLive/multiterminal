# ESPHome secrets for the MSR-2 presence sensor (task 9f9c3141, item 10).
# Copy to `secrets.yaml` next to msr2-presence.yaml and fill in. Do NOT commit secrets.yaml.
wifi_ssid: "Your 2.4GHz SSID"          # ESP32 is 2.4GHz only
wifi_password: "your-wifi-password"
mqtt_broker: "192.168.x.x"             # LAN IP of the box running Mosquitto

# --- item 11 (BLE), uncomment the matching lines in msr2-presence.yaml when ready ---
# iphone_irk: "0123456789abcdef0123456789abcdef"   # 16-byte IRK hex, capture per docs/presence-routing.md §7
# pixel_ibeacon_uuid: "00000000-0000-0000-0000-000000000000"
