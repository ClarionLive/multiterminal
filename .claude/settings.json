{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__windows-build-runner__build_project",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/active-context-hook.js"
          }
        ]
      },
      {
        "matcher": "mcp__multiterminal__build_project",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/active-context-hook.js"
          }
        ]
      },
      {
        "matcher": "mcp__multiterminal__update_task_checklist",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/pipeline-trigger-hook.js"
          },
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/active-context-hook.js"
          }
        ]
      },
      {
        "matcher": "mcp__multiterminal__update_task_status",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/active-context-hook.js"
          }
        ]
      },
      {
        "matcher": "mcp__multiterminal__update_task_continuation",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/DevLaptop/ClarionPowerShell/MultiTerminal/.claude/hooks/active-context-hook.js"
          }
        ]
      }
    ]
  }
}
